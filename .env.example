# LLM (Ollama — runs locally) 
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

#  Gmail 
# Use a Gmail App Password, NOT your account password
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Job Search Preferences 
JOB_TITLES=ML Engineer,Data Scientist,AI Engineer,Python Developer
JOB_LOCATIONS=Bangalore,Remote,Hyderabad,Mumbai
EXPERIENCE_LEVEL=internship

#  Limits & Safety 
# IMPORTANT: Start with DRY_RUN=true to test before sending real emails
DRY_RUN=true
MAX_EMAILS_PER_DAY=10
MAX_JOBS_PER_RUN=20
BLACKLIST_COMPANIES=

#  Paths 
BASE_RESUME_PATH=data/resumes/base_resume.txt
TAILORED_RESUME_DIR=data/resumes/tailored
JOBS_DB_PATH=data/jobs/jobs.json
APPLICATIONS_LOG=data/applications/applications.json
